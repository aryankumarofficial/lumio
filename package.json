{
  "name": "lumio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "rimraf node_modules .turbo",
    "clean:cache": "rimraf .turbo",
    "clean:modules": "rimraf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:build": "rimraf apps/*/.next apps/*/dist packages/*/dist",
    "reinstall": "pnpm run clean && pnpm install",
    "docker:up": "docker compose --env-file .env.docker up --build -d",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2"
    }
  }
}