# Copy to .env.docker and fill in secrets before running:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build -d

# Required
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Database (used by postgres + api + db-migrate services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=lumio

# Host ports
API_PORT=5000
WEB_PORT=3000

# Browser-facing URLs (must match how users reach the apps)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# AI (optional — required for note summarisation)
AI_API_KEY=
AI_BASE_URL=
AI_DEFAULT_MODEL=gemini-2.5-flash

JWT_EXPIRES_IN=7d
